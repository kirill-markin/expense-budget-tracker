# =============================================================================
# Local development (copy to .env and edit)
# =============================================================================

# --- Database ---

# Owner role (DDL, migrations only). Used by scripts/migrate.sh.
MIGRATION_DATABASE_URL=postgresql://tracker:tracker@localhost:5432/tracker

# App role (DML, RLS enforced). Used by the web process.
DATABASE_URL=postgresql://app:app@localhost:5432/tracker

# Worker role (INSERT on exchange_rates only). Used by the FX rate fetcher.
# WORKER_DATABASE_URL=postgresql://worker:worker@localhost:5432/tracker

# --- Auth ---

# Auth mode: "none" (default, localhost only) or "proxy" (trust reverse proxy header)
AUTH_MODE=none

# --- Server ---

# Bind address (default 127.0.0.1; set to 0.0.0.0 for Docker/proxy)
HOST=127.0.0.1

# CORS origin for CSRF checks
CORS_ORIGIN=http://localhost:3000

# --- API keys (optional, for AI chat features) ---

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Overridable defaults (have sensible defaults, set only if you need to change)
# =============================================================================

# Header name the reverse proxy sets (required when AUTH_MODE=proxy)
# AUTH_PROXY_HEADER=x-amzn-oidc-data

# Cognito logout configuration (required when AUTH_MODE=proxy)
# COGNITO_DOMAIN=auth.example.com
# COGNITO_CLIENT_ID=abc123def456

# =============================================================================
# AWS ECS environment (auto-injected by CDK — do NOT set manually)
#
# Source of truth: infra/aws/lib/compute.ts (environment + secrets blocks)
#                  infra/aws/lib/stack.ts   (addEnvironment calls after ingress)
#
# CDK resolves these from CloudFormation refs at deploy time.
# Listed here for reference when debugging a running container.
# =============================================================================
#
# AUTH_MODE=proxy
# AUTH_PROXY_HEADER=x-amzn-oidc-data
# HOSTNAME=0.0.0.0
# CORS_ORIGIN=https://app.example.com
# COGNITO_DOMAIN=auth.example.com
# COGNITO_CLIENT_ID=<from CDK props>
# COGNITO_REGION=<AWS::Region>
# DB_HOST=<RDS endpoint>
# DB_NAME=tracker
# DB_USER=app
# DB_PASSWORD=<from Secrets Manager>
# OPENAI_API_KEY=<from Secrets Manager>
# ANTHROPIC_API_KEY=<from Secrets Manager>
# NODE_EXTRA_CA_CERTS=/app/rds-global-bundle.pem
# ALB_ARN=<from CDK: ing.alb.loadBalancerArn>
# COGNITO_ISSUER=<from CDK: https://cognito-idp.REGION.amazonaws.com/POOL_ID>
